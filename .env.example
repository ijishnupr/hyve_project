# ---------------------------------------------------------------------------
# Copy to .env and adjust for your environment. NEVER commit the real .env.
# ---------------------------------------------------------------------------

# Core
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=core.settings

# Database
# Leave DATABASE_URL empty to fall back to local SQLite (dev only).
# Production example: postgres://user:password@host:5432/purchase
DATABASE_URL=

# CORS / CSRF (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT lifetimes (minutes / days)
JWT_ACCESS_TOKEN_LIFETIME_MIN=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email (console backend used when EMAIL_HOST is empty)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=procurement@example.com
